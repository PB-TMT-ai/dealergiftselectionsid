# Paste your Supabase project URL and service role key after creating the project.
# Find both at: Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...service_role_key_here...

# Any 32+ char random string. Generate with: openssl rand -hex 32
SESSION_SECRET=replace_me_with_a_32_char_random_string_xxxxxxxx
